# Bilibili SESSDATA cookie value.
BILIBILI_SESSDATA=your_bilibili_sessdata

# Bilibili buvid3 cookie value.
BILIBILI_BUVID3=your_bilibili_buvid3

# Bilibili buvid4 cookie value (device fingerprint, required since 2024).
BILIBILI_BUVID4=your_bilibili_buvid4

# Bilibili CSRF token (bili_jct cookie).
BILIBILI_BILI_JCT=your_bili_jct

# Bilibili user ID (DedeUserID cookie).
BILIBILI_DEDE_USER_ID=your_dede_user_id

# Bilibili user ID checksum (DedeUserID__ckMd5 cookie).
BILIBILI_DEDE_USER_ID_CKMD5=your_dede_user_id_ckmd5

# Full X cookie string (from DevTools → Network → any x.com request → Headers → Cookie).
# Must include ct0 (CSRF token) and auth_token values.
X_COOKIE_STRING="auth_token=xxx; ct0=yyy; twid=u%3D123; ..."

# SQLite database file path.
DB_PATH=data/posts.db

# Comma-separated Bilibili UID list.
BILIBILI_UIDS=123456,789012

# Comma-separated X username list; @ prefixes are allowed.
X_USERNAMES=@example_user,another_user
